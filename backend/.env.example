# ─────────────────────────────────────────────────────────────────
# StormersChatPipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── Oval Insights (RugbyViz) ──────────────────────────────────────
# Auth: HTTP Basic Auth — username + password (not a Bearer token)
# API docs: https://api.rugbyviz.com/swagger
OVAL_INSIGHTS_BASE_URL=https://api.rugbyviz.com/rugby/v1
OVAL_INSIGHTS_USERNAME=your_username_here
OVAL_INSIGHTS_PASSWORD=your_password_here

# Known IDs (do not change)
OVAL_URC_COMP_ID=1068
OVAL_CHAMPIONS_CUP_COMP_ID=1008
OVAL_CURRENT_SEASON_ID=202501
OVAL_STORMERS_TEAM_ID=3994

# ── PostgreSQL / Neon ─────────────────────────────────────────────
# The current R app and pipeline read individual PG_* variables.
PG_HOST=your_neon_host_here
PG_PORT=5432
PG_DBNAME=your_database_name_here
PG_USER=your_database_user_here
PG_PASSWORD=your_database_password_here
